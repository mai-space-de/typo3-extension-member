{
  "name": "maispace/mai-member",
  "description": "TYPO3 Extension: Mitglieder-Verwaltung (Record & Bewerbung)",
  "type": "typo3-cms-extension",
  "license": "GPL-2.0-or-later",
  "keywords": [
    "typo3",
    "member",
    "membership",
    "application"
  ],
  "authors": [
    {
      "name": "Joel Maximilian Mai",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.2",
    "typo3/cms-core": "^13.4",
    "typo3/cms-extbase": "^13.4",
    "typo3/cms-fluid": "^13.4",
    "typo3/cms-backend": "^13.4",
    "typo3/cms-frontend": "^13.4"
  },
  "require-dev": {
    "typo3/testing-framework": "^8.0",
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "Maispace\\MaiMember\\": "Classes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Maispace\\MaiMember\\Tests\\": "Tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "typo3/class-alias-loader": true,
      "typo3/cms-composer-installers": true
    }
  },
  "extra": {
    "typo3/cms": {
      "extension-key": "mai_member"
    },
    "branch-alias": {
      "dev-main": "13.0.x-dev"
    }
  }
}
