{
    "name": "maispace/member",
    "description": "TYPO3 Extension: Mitglieder-Verwaltung (Record & Bewerbung)",
    "type": "typo3-cms-extension",
    "license": "GPL-2.0-or-later",
    "keywords": [
        "typo3",
        "member",
        "membership",
        "application"
    ],
    "authors": [
        {
            "name": "Joel Maximilian Mai",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.1",
        "typo3/cms-core": "^12.0",
        "typo3/cms-extbase": "^12.0",
        "typo3/cms-fluid": "^12.0",
        "typo3/cms-backend": "^12.0",
        "typo3/cms-frontend": "^12.0"
    },
    "require-dev": {
        "typo3/testing-framework": "^8.0",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Maispace\\Member\\": "Classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Maispace\\Member\\Tests\\": "Tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "member"
        }
    }
}
