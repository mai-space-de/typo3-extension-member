{
  "name": "maispace/mai-member",
  "description": "TYPO3 Extension: Mitglieder-Verwaltung (Record & Bewerbung)",
  "type": "typo3-cms-extension",
  "license": "GPL-2.0-or-later",
  "keywords": [
    "typo3",
    "member",
    "membership",
    "application"
  ],
  "authors": [
    {
      "name": "Joel Maximilian Mai",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.2",
    "typo3/cms-backend": "^13.4",
    "typo3/cms-core": "^13.4",
    "typo3/cms-extbase": "^13.4",
    "typo3/cms-fluid": "^13.4",
    "typo3/cms-frontend": "^13.4"
  },
  "require-dev": {
    "armin/editorconfig-cli": "^2.1",
    "friendsofphp/php-cs-fixer": "^3.0",
    "helmich/typo3-typoscript-lint": "^3.1",
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^10.5 || ^11.0",
    "saschaegerer/phpstan-typo3": "^2.0",
    "typo3/testing-framework": "^8.0"
  },
  "autoload": {
    "psr-4": {
      "Maispace\\MaiMember\\": "Classes"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Maispace\\MaiMember\\Tests\\": "Tests"
    }
  },
  "scripts": {
    "lint:check": [
      "@check:editorconfig",
      "@check:phpcs",
      "@check:phpstan",
      "@check:typoscript",
      "@composer validate --strict --no-check-version --no-check-all --no-check-publish"
    ],
    "lint:fix": [
      "@fix:editorconfig",
      "@fix:phpcs",
      "@check:phpstan",
      "@check:typoscript"
    ],
    "check:editorconfig": "ec -unv -e vendor/ -e public/",
    "fix:editorconfig": "ec -unvf -e vendor/ -e public/",
    "check:phpcs": "PHP_CS_FIXER_IGNORE_ENV=1 php-cs-fixer check --config .php-cs-fixer.php --ansi --verbose --diff",
    "fix:phpcs": "PHP_CS_FIXER_IGNORE_ENV=1 php-cs-fixer fix --config .php-cs-fixer.php --ansi",
    "check:phpstan": "phpstan analyse --no-progress",
    "check:phpstan:baseline": "phpstan analyse --no-progress --generate-baseline=phpstan-baseline.neon",
    "check:typoscript": "typoscript-lint --fail-on-warnings -c typoscript-lint.yml Configuration/TypoScript/",
    "test": "phpunit --configuration phpunit.xml.dist",
    "test:unit": "phpunit --configuration phpunit.xml.dist --testsuite Unit"
  },
  "config": {
    "allow-plugins": {
      "typo3/class-alias-loader": true,
      "typo3/cms-composer-installers": true
    },
    "sort-packages": true
  },
  "extra": {
    "typo3/cms": {
      "extension-key": "mai_member"
    },
    "branch-alias": {
      "dev-main": "13.0.x-dev"
    }
  }
}
