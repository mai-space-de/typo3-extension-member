<?xml version="1.0" encoding="UTF-8"?>
<xliff version="1.2" xmlns="urn:oasis:names:tc:xliff:document:1.2">
    <file source-language="en" target-language="de" datatype="plaintext" original="messages" product-name="mai_member">
        <body>
            <trans-unit id="member.list.title">
                <source>Members</source>
                <target>Mitglieder</target>
            </trans-unit>
            <trans-unit id="member.detail.title">
                <source>Member Detail</source>
                <target>Mitgliederdetails</target>
            </trans-unit>
            <trans-unit id="member.notFound">
                <source>Member not found.</source>
                <target>Mitglied nicht gefunden.</target>
            </trans-unit>

            <trans-unit id="application.form.title">
                <source>Apply for Membership</source>
                <target>Mitglied werden</target>
            </trans-unit>
            <trans-unit id="application.form.firstName">
                <source>First Name</source>
                <target>Vorname</target>
            </trans-unit>
            <trans-unit id="application.form.lastName">
                <source>Last Name</source>
                <target>Nachname</target>
            </trans-unit>
            <trans-unit id="application.form.email">
                <source>Email</source>
                <target>E-Mail</target>
            </trans-unit>
            <trans-unit id="application.form.message">
                <source>Message</source>
                <target>Nachricht</target>
            </trans-unit>
            <trans-unit id="application.form.submit">
                <source>Submit Application</source>
                <target>Antrag absenden</target>
            </trans-unit>
            <trans-unit id="application.success.title">
                <source>Application Received</source>
                <target>Antrag eingegangen</target>
            </trans-unit>
            <trans-unit id="application.success.message">
                <source>Your membership application has been received. We will get back to you shortly.</source>
                <target>Dein Mitgliedsantrag ist bei uns eingegangen. Wir melden uns in Kürze bei dir.</target>
            </trans-unit>
            <trans-unit id="application.duplicate.title">
                <source>Duplicate Application</source>
                <target>Antrag bereits vorhanden</target>
            </trans-unit>
            <trans-unit id="application.duplicate.message">
                <source>An application with this email address already exists. If you have questions about your existing application, please contact us directly.</source>
                <target>Zu dieser E-Mail-Adresse liegt uns bereits ein Antrag vor. Bei Fragen zu deinem bestehenden Antrag melde dich bitte direkt bei uns.</target>
            </trans-unit>
            <trans-unit id="member.list.empty">
                <source>No members found.</source>
                <target>Keine Mitglieder gefunden.</target>
            </trans-unit>
            <trans-unit id="email.applicationReceived.subject">
                <source>We received your application</source>
                <target>Wir haben deinen Antrag erhalten</target>
            </trans-unit>
            <trans-unit id="email.applicationReceived.greeting">
                <source>Hello %s,</source>
                <target>Hallo %s,</target>
            </trans-unit>
            <trans-unit id="email.applicationReceived.body">
                <source>Thank you for your membership application. We have received it and will review it shortly.</source>
                <target>Vielen Dank für deinen Mitgliedsantrag. Wir haben ihn erhalten und prüfen ihn in Kürze.</target>
            </trans-unit>
            <trans-unit id="email.applicationApproved.subject">
                <source>Your application has been approved</source>
                <target>Dein Antrag wurde angenommen</target>
            </trans-unit>
            <trans-unit id="email.applicationApproved.greeting">
                <source>Hello %s,</source>
                <target>Hallo %s,</target>
            </trans-unit>
            <trans-unit id="email.applicationApproved.body">
                <source>Your membership application has been approved. Welcome!</source>
                <target>Dein Mitgliedsantrag wurde angenommen. Willkommen!</target>
            </trans-unit>
            <trans-unit id="email.applicationRejected.subject">
                <source>Update on your application</source>
                <target>Neuigkeiten zu deinem Antrag</target>
            </trans-unit>
            <trans-unit id="email.applicationRejected.greeting">
                <source>Hello %s,</source>
                <target>Hallo %s,</target>
            </trans-unit>
            <trans-unit id="email.applicationRejected.body">
                <source>Thank you for your interest. Unfortunately we are not able to accept your application at this time.</source>
                <target>Vielen Dank für dein Interesse. Leider können wir deinen Antrag derzeit nicht annehmen.</target>
            </trans-unit>
        </body>
    </file>
</xliff>
